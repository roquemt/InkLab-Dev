{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run UI Server",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/inklab-dashboard"
            },
            "isBackground": true,
            "presentation": {
                "group": "inklab",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "Compile FPGA",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}/rtl"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "group": "inklab",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}